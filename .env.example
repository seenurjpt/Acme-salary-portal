# Postgres connection string (e.g. Neon — free tier at https://neon.tech).
# For a fully-offline SQLite demo instead: set provider = "sqlite" in prisma/schema.prisma
# and DATABASE_URL="file:./dev.db".
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="dev-secret-change-me"

# Seeded HR Manager login (used by the credentials provider)
HR_EMAIL="hr@acme.com"
HR_PASSWORD="password123"

# Optional: enables the AI natural-language Q&A. If unset, the app falls back to a
# deterministic local parser so the feature still works offline.
# GEMINI_API_KEY has a free tier — get one at https://aistudio.google.com
GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-3.1-flash-lite-preview"  # optional override (this is the default)
